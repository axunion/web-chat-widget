{
	"enableAllProjectMcpServers": false,
	"enabledMcpjsonServers": [],
	"allowedMcpServers": [],
	"hooks": {
		"PostToolUse": [
			{
				"matcher": "Edit|Write",
				"hooks": [
					{
						"type": "command",
						"command": "input=$(cat); f=$(echo \"$input\" | jq -r '.tool_input.file_path // .tool_response.filePath // \"\"'); case \"$f\" in */package.json|package.json) [ -f \"$f\" ] && jq -e '((.dependencies // {}) | length) + ((.peerDependencies // {}) | length) > 0' \"$f\" >/dev/null 2>&1 && echo '{\"systemMessage\":\"⚠ Zero-deps invariant violated: package.json now declares runtime dependencies. Per .claude/rules/zero-deps.md and SPEC §11.5, dependencies and peerDependencies must stay empty.\"}' ;; esac; true"
					},
					{
						"type": "command",
						"command": "input=$(cat); f=$(echo \"$input\" | jq -r '.tool_input.file_path // .tool_response.filePath // \"\"'); case \"$f\" in */src/*.ts|*/src/*.tsx|*/src/*.js) (cd \"$(git rev-parse --show-toplevel 2>/dev/null || echo .)\" && pnpm exec biome check --write \"$f\" >/dev/null 2>&1) ;; esac; true"
					}
				]
			}
		]
	},
	"permissions": {
		"allow": [
			"Bash(git *)",
			"Bash(gh *)",
			"Bash(ls)",
			"Bash(ls *)",
			"Bash(pwd)",
			"Bash(which *)",
			"Bash(wc *)",
			"Bash(file *)",
			"Bash(tree *)",
			"Bash(grep *)",
			"Bash(head *)",
			"Bash(tail *)",
			"Bash(echo *)",
			"Bash(pnpm *)",
			"Bash(mkdir *)",
			"Bash(find *)",
			"Bash(rg *)",
			"Bash(jq *)",
			"WebSearch"
		],
		"deny": [
			"Bash(git push --force *)",
			"Bash(git push -f *)",
			"Bash(git push --force-with-lease *)",
			"Bash(git reset --hard *)",
			"Bash(git clean -f *)",
			"Bash(git clean -fd *)",
			"Bash(git branch -D *)",
			"Bash(git checkout .)",
			"Bash(git checkout -- .)",
			"Bash(git restore .)",
			"Bash(git update-ref *)",
			"Bash(git filter-branch *)",
			"Bash(git filter-repo *)",
			"Bash(gh repo delete *)",
			"Bash(gh ssh-key add *)",
			"Bash(gh auth logout *)",
			"Bash(gh secret *)",
			"Bash(rm -rf *)",
			"Bash(rm -fr *)",
			"Bash(rm -r *)",
			"Bash(rm --recursive *)",
			"Bash(sudo *)",
			"Bash(doas *)",
			"Bash(su *)",
			"Bash(cat ~/.ssh/*)",
			"Bash(cat ~/.aws/*)",
			"Bash(cat ~/.gnupg/*)",
			"Bash(head ~/.ssh/*)",
			"Bash(head ~/.aws/*)",
			"Bash(head ~/.gnupg/*)",
			"Bash(tail ~/.ssh/*)",
			"Bash(tail ~/.aws/*)",
			"Bash(tail ~/.gnupg/*)",
			"Bash(less ~/.ssh/*)",
			"Bash(less ~/.aws/*)",
			"Bash(less ~/.gnupg/*)",
			"Bash(more ~/.ssh/*)",
			"Bash(more ~/.aws/*)",
			"Bash(more ~/.gnupg/*)",
			"Read(~/.ssh/*)",
			"Read(~/.aws/*)",
			"Read(~/.gnupg/*)",
			"Read(**/.env*)",
			"Read(**/*.pem)",
			"Read(**/*.key)",
			"Edit(~/.bashrc)",
			"Edit(~/.zshrc)",
			"Edit(~/.bash_profile)",
			"Edit(~/.zprofile)",
			"Edit(~/.zshenv)",
			"Edit(~/.profile)",
			"Write(~/.bashrc)",
			"Write(~/.zshrc)",
			"Write(~/.bash_profile)",
			"Write(~/.zprofile)",
			"Write(~/.zshenv)",
			"Write(~/.profile)"
		]
	}
}
