{
  "name": "web-chat-widget",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./element": {
      "types": "./dist/element.d.ts",
      "import": "./dist/element.js"
    },
    "./adapters": {
      "types": "./dist/adapters/index.d.ts",
      "import": "./dist/adapters.js"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build && vite build --mode iife && tsc -p tsconfig.build.json && node scripts/rewrite-dts-extensions.mjs",
    "typecheck": "tsc",
    "preview": "vite preview",
    "check": "biome check ./src",
    "check:write": "biome check --write ./src",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "happy-dom": "^20.9.0",
    "typescript": "~6.0.2",
    "vite": "^8.0.9",
    "vitest": "^4.1.4"
  },
  "volta": {
    "node": "24.15.0"
  }
}
